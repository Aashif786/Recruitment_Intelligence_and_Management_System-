# ==============================================================================
# CALRIMS Backend — Environment Variables Template
# ==============================================================================
# Copy this file to `.env` and fill in the values for your environment.
#   cp .env.example .env
#
# Variables marked [REQUIRED] will cause a fatal startup error if missing.
# Variables marked [CRITICAL] are required in production but optional in dev.
# Variables marked [OPTIONAL] enable additional features when set.
# ==============================================================================

# --- Environment ---
ENV=development                          # "development" or "production"
DEBUG=false                              # Set to true for verbose SQL echo + error detail in responses

# --- Database [REQUIRED] ---
DATABASE_URL=postgresql://user:password@localhost:5432/rims_db
# For local SQLite (dev only): sqlite:///./rims.db

# --- JWT Authentication [REQUIRED] ---
JWT_SECRET=                              # Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=120
JWT_REFRESH_EXPIRATION_DAYS=7

# --- Encryption [CRITICAL] ---
ENCRYPTION_KEY=                          # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- AI / LLM Provider Keys [CRITICAL — at least one required] ---
GROQ_API_KEY=                            # Primary AI provider (Groq Cloud)
OPENAI_API_KEY=                          # Comma-separated for rotation: key1,key2
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Supabase Storage [CRITICAL] ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=                            # Service role key (server-side only)
SUPABASE_ANON_KEY=                       # Anon/public key
SUPABASE_SERVICE_ROLE_KEY=               # Same as SUPABASE_KEY if using service role
SUPABASE_BUCKET_RESUMES=resumes
SUPABASE_BUCKET_OFFERS=offers
SUPABASE_BUCKET_ID_CARDS=id-cards
SUPABASE_BUCKET_ID_PHOTOS=id-photos
SUPABASE_BUCKET_VIDEOS=videos

# --- Super Admin Bootstrap [OPTIONAL] ---
# Auto-creates a super admin account on first startup if no super_admin exists.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=                    # Use a strong password; will be bcrypt-hashed
SUPER_ADMIN_FULL_NAME=Super Admin

# --- SMTP Email [OPTIONAL — needed for notifications] ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=                           # Gmail App Password (16-char)
SMTP_FROM=your-email@gmail.com

# --- IMAP Email Ingestion [OPTIONAL — needed for resume auto-sync] ---
IMAP_EMAIL=your-email@gmail.com
IMAP_PASSWORD=                           # Same as SMTP_PASSWORD for Gmail

# --- Resend Email API [OPTIONAL — alternative to SMTP] ---
RESEND_API_KEY=
RESEND_FROM=

# --- Brevo Email API [OPTIONAL — alternative to SMTP] ---
BREVO_API_KEY=

# --- Redis [OPTIONAL — enables distributed idempotency + caching] ---
REDIS_URL=                               # redis://localhost:6379/0

# --- Frontend URL ---
FRONTEND_BASE_URL=http://localhost:3000/calrims

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Server ---
HOST=127.0.0.1
PORT=10000

# --- Observability [OPTIONAL] ---
SENTRY_DSN=
AI_OBSERVABILITY_ENABLED=true

# --- LinkedIn Integration [OPTIONAL] ---
ENABLE_LINKEDIN_POSTING=false
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# --- Company Branding ---
COMPANY_NAME=Your Company Name

# --- Advanced Tuning ---
IDEMPOTENCY_TTL_MIN_SECONDS=60
IDEMPOTENCY_TTL_MAX_SECONDS=120
ENABLE_REQUEST_ID_IDEMPOTENCY=true
WS_ENFORCE_INTERVIEW_JWT=false           # Auto-enabled in production
AI_TIMEOUT_SECONDS=45
